# Terraform .gitignore

# Local .terraform directories

**/.terraform/*

# Terraform state files

*.tfstate
*.tfstate.*

# Crash log files

crash.log
crash.*.log

# Exclude sensitive variable files

*.tfvars
*.tfvars.json

# Ignore override files

override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore Terraform CLI config files

.terraformrc
terraform.rc

# Ignore plan files

*.tfplan

# Ignore lock file if you prefer (optional)

.terraform.lock.hcl

# Ignore environment variable files

.env
.env.*

# Mac system files

.DS_Store

# Windows system files

Thumbs.db
